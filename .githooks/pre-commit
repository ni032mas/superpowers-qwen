#!/usr/bin/env bash

# Pre-commit hook: Prevent direct commits to the 'dev' branch.

branch=$(git symbolic-ref --short HEAD 2>/dev/null)

# Skip check on detached HEAD (rebase, cherry-pick, etc.)
if [ -z "$branch" ]; then
    exit 0
fi

if [ "$branch" = "dev" ]; then
    echo ""
    echo "╔══════════════════════════════════════════════════════════╗"
    echo "║  GIT HOOK: pre-commit                                   ║"
    echo "╠══════════════════════════════════════════════════════════╣"
    echo "║  ERROR: Direct commits to 'dev' are not allowed.        ║"
    echo "║                                                         ║"
    echo "║  How to fix:                                            ║"
    echo "║    git checkout -b feature/my-feature dev                ║"
    echo "║    git checkout -b fix/my-fix dev                        ║"
    echo "╚══════════════════════════════════════════════════════════╝"
    echo ""
    exit 1
fi

exit 0
